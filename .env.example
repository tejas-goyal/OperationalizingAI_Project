# === Crypto Volatility Spike Detector ===

# Kafka
KAFKA_BOOTSTRAP=localhost:9092

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5001

# API
MODEL_VARIANT=ml          # "ml" for XGBoost, "baseline" for z-score rule

# Coinbase WebSocket
COINBASE_PAIRS=BTC-USD,ETH-USD
INGEST_MINUTES=60

# Grafana (set in compose, listed here for reference)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
