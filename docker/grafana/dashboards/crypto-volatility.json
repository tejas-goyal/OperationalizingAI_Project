  "id": 1,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "ms"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "list"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{handler='/predict'}[5m])) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{handler='/predict'}[5m])) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "title": "Predict Latency (ms)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "rate(http_requests_total{handler='/predict'}[5m])",
          "legendFormat": "requests/sec",
          "refId": "A"
        }
      ],
      "title": "Request Rate (/predict)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "percentunit"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "targets": [
        {
          "expr": "rate(http_requests_total{handler='/predict', status_code!~'2..'}[5m]) / rate(http_requests_total{handler='/predict'}[5m])",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ],
      "title": "Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "targets": [
        {
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "title": "All Endpoint Traffic",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 30},
              {"color": "red", "value": 60}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 16},
      "id": 5,
      "targets": [
        {
          "expr": "time() - last_event_timestamp_seconds",
          "legendFormat": "seconds since last event",
          "refId": "A"
        }
      ],
      "title": "Data Freshness",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 100},
              {"color": "red", "value": 1000}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 16},
      "id": 6,
      "targets": [
        {
          "expr": "kafka_consumer_lag",
          "legendFormat": "lag (messages)",
          "refId": "A"
        }
      ],
      "title": "Kafka Consumer Lag",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"text": "DOWN"}, "1": {"text": "UP"}}, "type": "value"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 16},
      "id": 7,
      "targets": [
        {
          "expr": "up{job=\"crypto-api\"}",
          "refId": "A"
        }
      ],
      "title": "API Uptime",
      "type": "stat"
    },
    {
      "alert": {
        "conditions": [
          {
            "evaluator": {"params": [800], "type": "gt"},
            "operator": {"type": "and"},
            "query": {"params": ["A", "5m", "now"]},
            "reducer": {"type": "avg"},
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "for": "1m",
        "frequency": "30s",
        "name": "High p95 Latency Alert",
        "message": "p95 predict latency exceeded 800ms for 1 minute",
        "noDataState": "no_data"
      },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "ms"},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 16},
      "id": 8,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{handler='/predict'}[5m])) * 1000",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "title": "p95 Latency Alert (> 800ms)",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
